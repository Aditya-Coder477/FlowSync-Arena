# FlowSync Arena — Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# This file documents ALL environment variables needed for Cloud Run deployment.
# DO NOT commit actual values. Use Google Cloud Secret Manager for secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── BACKEND (set as Cloud Run env vars for flowsync-api service) ──────────────

# Your GCP project ID
GOOGLE_CLOUD_PROJECT=flowsync-arena

# Runtime environment identifier
ENVIRONMENT=production

# Disable debug output in production
DEBUG=false

# CORS: Comma-separated list of allowed frontend origins.
# Set this to your frontend Cloud Run URL AFTER deploying the frontend.
# Example: https://flowsync-web-xxxxxxxxxx-ew.a.run.app
ALLOWED_ORIGINS=https://YOUR_FRONTEND_CLOUD_RUN_URL

# ── Redis (leave all empty to disable Redis in production) ───────────────────
# To enable: provision Google Cloud Memorystore for Redis and set these values.
# Cloud Run also requires a VPC Connector to reach Memorystore.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── NOTE: GOOGLE_APPLICATION_CREDENTIALS ─────────────────────────────────────
# Do NOT set this in Cloud Run. The service automatically uses the
# service account attached to the Cloud Run service via ADC.
# Only set this locally when using a service account key JSON file.

# ─────────────────────────────────────────────────────────────────────────────
# ── FRONTEND (set as build-time Docker ARG, NOT runtime env var) ──────────────
# ─────────────────────────────────────────────────────────────────────────────

# The backend Cloud Run URL. This is baked into the Next.js bundle at build time.
# Get this after deploying the backend service:
#   gcloud run services describe flowsync-api --region=asia-south1 --format='value(status.url)'
NEXT_PUBLIC_API_URL=https://YOUR_BACKEND_CLOUD_RUN_URL
