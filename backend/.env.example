# ──────────────────────────────────────────────────────────────────────────────
# FlowSync Arena — Backend Environment Configuration
#
# Copy this file to .env and fill in your values for local development.
# In Cloud Run, these are set as Cloud Run environment variables (or fetched
# from Secret Manager when CLOUD_SECRET_MANAGER_ENABLED=true).
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FlowSync Arena API
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Google Cloud ──────────────────────────────────────────────────────────────
# Your GCP project ID (same project that has Firestore enabled)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to service account JSON key (local development ONLY).
# In Cloud Run, leave this blank — the attached service account (ADC) is used.
# The service account needs: roles/datastore.user (Firestore read/write)
GOOGLE_APPLICATION_CREDENTIALS=./secrets/sa-key.json

# ── Google Cloud Logging ──────────────────────────────────────────────────────
# Set to true in production to route all Python logs to Cloud Logging.
# Requires: google-cloud-logging>=3.10.0 installed in the container.
# Locally: keep false — standard Python logging is used.
CLOUD_LOGGING_ENABLED=false

# ── Google Cloud Secret Manager ───────────────────────────────────────────────
# When true (production), the app fetches runtime secrets from Secret Manager.
#
# Secret Manager setup (one-time per secret):
#   gcloud secrets create REDIS_PASSWORD --replication-policy="automatic"
#   echo -n "your-redis-password" | gcloud secrets versions add REDIS_PASSWORD --data-file=-
#
# Grant your Cloud Run service account access:
#   gcloud secrets add-iam-policy-binding REDIS_PASSWORD \
#     --member="serviceAccount:YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com" \
#     --role="roles/secretmanager.secretAccessor"
#
# The code uses: from app.services.secret_manager import get_secret
#   redis_password = get_secret("REDIS_PASSWORD")  # SM in prod, env var locally
#
CLOUD_SECRET_MANAGER_ENABLED=false

# ── Redis / Cloud Memorystore ─────────────────────────────────────────────────
# Leave REDIS_HOST empty to disable Redis entirely (app falls back to Firestore).
# For local dev with Docker: use 'localhost'
# For Cloud Memorystore: use the private IP address (e.g. 10.0.0.3)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=                  # Use Secret Manager in production
REDIS_DB=0
REDIS_TLS=false                  # Set true for Cloud Memorystore with TLS

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
ZONE_DENSITY_TTL=30
SESSION_TTL=3600
ALERT_TTL=300
QUEUE_STATE_TTL=20
ADMIN_ANALYTICS_TTL=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production: set to your Cloud Run frontend URL (no trailing slash).
#   ALLOWED_ORIGINS=https://flowsync-web-xxx.run.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Crowd Thresholds ──────────────────────────────────────────────────────────
ZONE_GREEN_THRESHOLD=0.50
ZONE_AMBER_THRESHOLD=0.75
ZONE_RED_THRESHOLD=0.90
CALM_MODE_TRIGGER=0.70
