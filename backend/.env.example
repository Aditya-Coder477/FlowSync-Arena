# FlowSync Arena — Backend Local Dev Environment
# Copy this file to .env (already done if you ran run_app.bat)
# Fill in GOOGLE_APPLICATION_CREDENTIALS with the path to your service account JSON.

# Google Cloud
GOOGLE_CLOUD_PROJECT=flowsync-arena
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Redis — local Redis via Docker (matches docker-compose redis service)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# App
ENVIRONMENT=development
DEBUG=true

# CORS — allow local frontend
ALLOWED_ORIGINS=http://localhost:3000
