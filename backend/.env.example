# FlowSync Arena — Backend Environment Variables
# Copy this to .env and fill in values. NEVER commit .env to version control.

# Google Cloud
GOOGLE_CLOUD_PROJECT=flowsync-arena
# For local dev only — point to your service account key JSON
# In Cloud Run, leave blank and use ADC automatically
GOOGLE_APPLICATION_CREDENTIALS=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# App
ENVIRONMENT=development
DEBUG=false

# CORS (comma-separated origins for production)
# ALLOWED_ORIGINS=["https://your-frontend.run.app"]
